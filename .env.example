# .env.local

# Required
OPENAI_API_KEY=sk-...

# Optional — Alpha Vantage free tier for market data (use "demo" for development)
ALPHA_VANTAGE_API_KEY=demo

# Optional — comma-separated extra allowed origins for origin-check
ALLOWED_ORIGINS=

# Optional — override defaults
OPENAI_MODEL=gpt-4o
OPENAI_TIMEOUT_MS=30000
OPENAI_RETRY_ATTEMPTS=2
OPENAI_RETRY_DELAY_MS=1000
MAX_TOOL_ROUNDS=6
MAX_CONTEXT_MESSAGES=40
MAX_CONTEXT_CHARACTERS=80000
DB_PATH=data/finance-chat.db

# Auth (spec 10)
# Required — generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional — max anonymous messages per 24h window (default: 5)
ANON_MESSAGE_LIMIT=5

